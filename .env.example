# Supabase — URL y claves del proyecto (dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (email transaccional) — API key desde https://resend.com/api-keys
RESEND_API_KEY=

# Cloudflare Turnstile (captcha) — https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Anthropic (IA para verificación de identidad con cédula + selfie)
ANTHROPIC_API_KEY=
